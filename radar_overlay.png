/* ======================================================
   ANDHRA PRADESH FLOOD INTELLIGENCE CONTROL CENTER
   Advanced Professional Visualization Theme
====================================================== */

* {
    box-sizing: border-box;
}

body {
    margin: 0;
    font-family: "Segoe UI", Arial, sans-serif;
    background: radial-gradient(circle at top, #0a192f, #08101f 70%);
    color: #ffffff;
}

/* ================= TOPBAR ================= */

.topbar {
    background: linear-gradient(to right, #000814, #001d3d);
    padding: 15px 30px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 2px solid #00eaff;
    box-shadow: 0 4px 25px rgba(0,0,0,0.7);
}

.logo {
    font-weight: bold;
    font-size: 20px;
    color: #00eaff;
    letter-spacing: 1px;
}

.nav-buttons {
    display: flex;
    gap: 15px;
}

.nav-btn {
    padding: 8px 18px;
    background: linear-gradient(135deg, #00eaff, #0077ff);
    border-radius: 6px;
    text-decoration: none;
    color: #fff;
    font-size: 13px;
    font-weight: 500;
    transition: 0.3s ease;
}

.nav-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 234, 255, 0.6);
}

/* ================= ALERT ================= */

.alert-banner {
    background: linear-gradient(to right, #ff0033, #990000);
    padding: 14px;
    text-align: center;
    font-weight: bold;
    letter-spacing: 1px;
    animation: blink 1s infinite;
    box-shadow: 0 0 20px rgba(255,0,0,0.7);
}

.hidden {
    display: none;
}

@keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
}

/* ================= MAIN LAYOUT ================= */

.main-container {
    display: flex;
    padding: 25px;
    gap: 25px;
}

/* ================= LEFT PANEL ================= */

.left-panel {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 25px;
}

/* ================= PREDICTION BOX ================= */

.prediction-box {
    background: rgba(10, 25, 47, 0.85);
    padding: 22px;
    border-radius: 14px;
    border: 1px solid #00eaff55;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter:blur(8px);
    box-shadow: 0 0 30px rgba(0, 234, 255, 0.25);
}

.prediction-box h2 {
    margin-top: 0;
    font-size: 18px;
    color: #00eaff;
}

.risk-box {
    padding: 18px;
    font-size: 24px;
    font-weight: bold;
    border-radius: 10px;
    text-align: center;
    margin-bottom: 15px;
    transition: 0.3s ease;
}

.risk-low {
    background: linear-gradient(135deg, #2ecc71, #1e8449);
}

.risk-medium {
    background: linear-gradient(135deg, #f1c40f, #d4ac0d);
    color: #000;
}

.risk-high {
    background: linear-gradient(135deg, #e74c3c, #922b21);
    box-shadow: 0 0 20px rgba(255,0,0,0.6);
}

/* ================= CONFIDENCE ================= */

.confidence-container {
    margin-top: 12px;
}

.progress-bar {
    width: 100%;
    height: 18px;
    background: #111;
    border-radius: 20px;
    overflow: hidden;
    border: 1px solid #00eaff33;
}

#confidence-bar {
    height: 100%;
    width: 0%;
    background: linear-gradient(to right, #00eaff, #0077ff);
    transition: width 0.4s ease-in-out;
}

/* ================= WEATHER METRICS ================= */

.weather-metrics {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
}

.metric {
    background: rgba(0, 40, 80, 0.7);
    padding: 12px;
    border-radius: 10px;
    border: 1px solid #00eaff22;
    font-size: 13px;
    transition: 0.2s ease;
}

.metric:hover {
    transform: translateY(-3px);
    box-shadow: 0 0 15px rgba(0, 234, 255, 0.3);
}

.metric.snow {
    background: linear-gradient(135deg, #102030, #08131f);
    border: 1px solid #00eaff55;
}

/* ================= SATELLITE ================= */

.satellite-box {
    background: rgba(0, 40, 80, 0.7);
    padding: 15px;
    border-radius: 12px;
    border: 1px solid #00eaff55;
    box-shadow: 0 0 20px rgba(0, 234, 255, 0.2);
}

.satellite-box h3 {
    margin-top: 0;
    color: #00eaff;
}

/* ================= RIGHT PANEL ================= */

.right-panel {
    flex: 2;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 25px;
}

/* ================= CHART CARDS ================= */

.chart-card {
    background: rgba(10, 25, 47, 0.9);
    padding: 18px;
    border-radius: 14px;
    border: 1px solid #00eaff33;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter:blur(6px);
    box-shadow: 0 0 20px rgba(0, 234, 255, 0.15);
}

.chart-card h3 {
    margin-top: 0;
    color: #00eaff;
    font-size: 15px;
}

/* ================= MAP ================= */

.map-card {
    grid-column: span 2;
    background: rgba(10, 25, 47, 0.95);
    padding: 20px;
    border-radius: 14px;
    border: 1px solid #00eaff;
    box-shadow: 0 0 30px rgba(0, 234, 255, 0.25);
}

#map {
    height: 520px;
    border-radius: 10px;
    border: 1px solid #00eaff44;
}

/* ================= TREND GRID ================= */

.trend-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
    gap: 25px;
    padding: 20px;
}

.trend-card {
    background: rgba(10, 25, 47, 0.85);
    border-radius: 15px;
    padding: 18px;
    border: 1px solid #00eaff33;
    box-shadow: 0 0 18px rgba(0, 234, 255, 0.15);
}

.trend-card h3 {
    margin-bottom: 10px;
    font-size: 15px;
    color: #00eaff;
}

/* ================= RESPONSIVE ================= */

@media (max-width: 1200px) {

    .main-container {
        flex-direction: column;
    }

    .right-panel {
        grid-template-columns: 1fr;
    }

    .map-card {
        grid-column: span 1;
    }
}
/* ================= WATER LEVEL ================= */

.water-level-container {
    background: rgba(0,20,40,0.85);
    padding: 20px;
    border-radius: 14px;
    border: 1px solid #00eaff55;
    text-align: center;
}

.water-tank {
    position: relative;
    width: 120px;
    height: 200px;
    margin: 15px auto;
    border-radius: 10px;
    border: 2px solid #00eaff;
    overflow: hidden;
    background: #08101f;
    box-shadow: inset 0 0 20px rgba(0,234,255,0.3);
}

.water-fill {
    position: absolute;
    bottom: 0;
    width: 100%;
    height: 0%;
    background: linear-gradient(to top, #0077ff, #00eaff);
    transition: height 1s ease-in-out;
    animation: wave 2s infinite linear;
}

@keyframes wave {
    0% { filter: brightness(1); }
    50% { filter: brightness(1.2); }
    100% { filter: brightness(1); }
}

.water-value {
    position: absolute;
    width: 100%;
    top: 50%;
    transform: translateY(-50%);
    font-weight: bold;
    font-size: 18px;
    color: white;
    text-shadow: 0 0 10px #00eaff;
}

/* ================= MISSION TIMER ================= */

.mission-timer {
    font-weight: bold;
    color: #00eaff;
    font-size: 14px;
}